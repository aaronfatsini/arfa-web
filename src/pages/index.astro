---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Premium Real Estate Photography">
	<main class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
		
    <!-- Hero Section -->
    <header class="min-h-screen flex flex-col justify-center items-center text-center py-20">
      <div class="animate-fade-in">
        <h2 class="text-sm uppercase tracking-widest text-gray-400 mb-4">ARFA STUDIOS</h2>
        <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6 bg-gradient-to-b from-white to-gray-500 bg-clip-text text-transparent">
          Vendemos tu inmueble <br /> antes de que lo publiquen.
        </h1>
        <p class="text-lg md:text-xl text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed font-light">
          Fotografía de alta gama, tomas con dron y vídeo cinematográfico para propiedades que no aceptan menos que la excelencia.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#contacto" class="bg-white text-black px-8 py-4 rounded-full font-semibold hover:bg-gray-200 transition-all duration-300 transform hover:scale-105">
            Reservar ahora
          </a>
          <a href="#servicios" class="border border-white/20 px-8 py-4 rounded-full font-semibold hover:bg-white/5 transition-all duration-300">
            Ver servicios
          </a>
        </div>
      </div>
    </header>

    <!-- Services Grid -->
    <section id="servicios" class="py-24">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="group bg-[#1c1c1c] p-10 rounded-3xl border border-white/5 hover:border-white/10 transition-all duration-500">
          <div class="mb-6 opacity-80 group-hover:opacity-100 transition-opacity">📸</div>
          <h3 class="text-2xl font-semibold mb-4">Pack Básico</h3>
          <p class="text-gray-400 mb-6 font-light leading-relaxed">
            Esencial para destacar en portales. 15 fotos profesionales (Interior/Exterior) con edición HDR y corrección de perspectiva.
          </p>
          <div class="text-3xl font-bold mb-6">150€ <span class="text-sm font-normal text-gray-500">IVA incl.</span></div>
          <a href="#contacto" class="inline-flex items-center text-white font-semibold">
            Saber más <span class="ml-2 group-hover:translate-x-1 transition-transform">→</span>
          </a>
        </div>

        <div class="group bg-[#1c1c1c] p-10 rounded-3xl border border-white/5 hover:border-white/10 transition-all duration-500 relative overflow-hidden">
          <div class="absolute top-6 right-6 bg-white text-black text-[10px] font-bold px-3 py-1 rounded-full uppercase">Popular</div>
          <div class="mb-6 opacity-80 group-hover:opacity-100 transition-opacity">🚁</div>
          <h3 class="text-2xl font-semibold mb-4">Pack Completo</h3>
          <p class="text-gray-400 mb-6 font-light leading-relaxed">
            La experiencia total. Incluye fotografía interior/exterior, 5 tomas aéreas con dron y un video vertical de 60 segundos.
          </p>
          <div class="text-3xl font-bold mb-6">200€ <span class="text-sm font-normal text-gray-500">IVA incl.</span></div>
          <a href="#contacto" class="inline-flex items-center text-white font-semibold">
            Saber más <span class="ml-2 group-hover:translate-x-1 transition-transform">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Visual Portfolio (Placeholders) -->
    <section class="py-24">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="aspect-square bg-gray-800 rounded-2xl animate-pulse"></div>
        <div class="aspect-square bg-gray-700 rounded-2xl animate-pulse delay-75"></div>
        <div class="aspect-square bg-gray-800 rounded-2xl animate-pulse delay-150"></div>
        <div class="aspect-square bg-gray-700 rounded-2xl animate-pulse delay-300"></div>
      </div>
    </section>

    <!-- Contact CTA -->
    <section id="contacto" class="py-32 text-center">
      <h2 class="text-4xl md:text-5xl font-bold mb-8">¿Listo para elevar tu propiedad?</h2>
      <p class="text-gray-400 mb-12 max-w-xl mx-auto">
        Atención personalizada en menos de 1 hora.
      </p>
      <a href="#" class="inline-block bg-white text-black px-12 py-5 rounded-full text-xl font-bold hover:scale-105 transition-transform">
        Hablar por WhatsApp
      </a>
    </section>

	</main>

  <footer class="py-12 border-t border-white/5 text-center text-gray-600 text-sm">
    <p>&copy; 2026 ARFA Studios. Deltebre - Tarragona.</p>
  </footer>
</Layout>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 1.2s ease-out forwards;
  }
</style>

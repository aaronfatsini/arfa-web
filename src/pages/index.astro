---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Premium Real Estate Photography">
	<main class="max-w-screen-xl mx-auto px-4 sm:px-6 lg:px-8">
		
    <!-- Hero Section -->
    <header class="relative min-h-screen flex flex-col justify-center items-center text-center py-20 overflow-hidden">
      <!-- Background Image -->
      <div class="absolute inset-0 z-0">
        <img src="https://images.unsplash.com/photo-1600607687920-4e2a09cf159d?auto=format&fit=crop&q=90&w=2000" alt="Background" class="object-cover object-center w-full h-full opacity-40 scale-105 animate-slow-zoom" />
        <div class="absolute inset-0 bg-gradient-to-b from-[#121212]/60 via-[#121212]/80 to-[#121212]"></div>
      </div>

      <div class="relative z-10 animate-fade-in px-4">
        <h2 class="text-sm uppercase tracking-[0.3em] text-white/60 mb-6 font-semibold">ARFA STUDIOS</h2>
        <h1 class="text-5xl md:text-8xl font-bold tracking-tight mb-8 bg-gradient-to-b from-white to-gray-400 bg-clip-text text-transparent leading-tight">
          Vendemos tu inmueble <br /> antes de que lo publiquen.
        </h1>
        <p class="text-lg md:text-2xl text-gray-300 max-w-3xl mx-auto mb-12 leading-relaxed font-light">
          Fotografía de alta gama, tomas con dron y vídeo cinematográfico para propiedades que no aceptan menos que la excelencia.
        </p>
        <div class="flex flex-col sm:flex-row gap-6 justify-center">
          <a href="#contacto" class="bg-white text-black px-10 py-4 rounded-full font-bold hover:bg-gray-200 transition-all duration-300 transform hover:scale-105 shadow-lg shadow-white/5">
            Reservar ahora
          </a>
          <a href="#servicios" class="bg-white/10 backdrop-blur-md border border-white/20 px-10 py-4 rounded-full font-bold hover:bg-white/20 transition-all duration-300">
            Ver servicios
          </a>
        </div>
      </div>
    </header>

    <!-- Services Grid -->
    <section id="servicios" class="py-24">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="group bg-[#1c1c1c] p-10 rounded-3xl border border-white/5 hover:border-white/10 transition-all duration-500">
          <div class="mb-6 opacity-80 group-hover:opacity-100 transition-opacity">📸</div>
          <h3 class="text-2xl font-semibold mb-4">Pack Básico</h3>
          <p class="text-gray-400 mb-6 font-light leading-relaxed">
            Esencial para destacar en portales. 15 fotos profesionales (Interior/Exterior) con edición HDR y corrección de perspectiva.
          </p>
          <div class="text-3xl font-bold mb-6">150€ <span class="text-sm font-normal text-gray-500">IVA incl.</span></div>
          <a href="#contacto" class="inline-flex items-center text-white font-semibold">
            Saber más <span class="ml-2 group-hover:translate-x-1 transition-transform">→</span>
          </a>
        </div>

        <div class="group bg-[#1c1c1c] p-10 rounded-3xl border border-white/5 hover:border-white/10 transition-all duration-500 relative overflow-hidden">
          <div class="absolute top-6 right-6 bg-white text-black text-[10px] font-bold px-3 py-1 rounded-full uppercase">Popular</div>
          <div class="mb-6 opacity-80 group-hover:opacity-100 transition-opacity">🚁</div>
          <h3 class="text-2xl font-semibold mb-4">Pack Completo</h3>
          <p class="text-gray-400 mb-6 font-light leading-relaxed">
            La experiencia total. Incluye fotografía interior/exterior, 5 tomas aéreas con dron y un video vertical de 60 segundos.
          </p>
          <div class="text-3xl font-bold mb-6">200€ <span class="text-sm font-normal text-gray-500">IVA incl.</span></div>
          <a href="#contacto" class="inline-flex items-center text-white font-semibold">
            Saber más <span class="ml-2 group-hover:translate-x-1 transition-transform">→</span>
          </a>
        </div>
      </div>
    </section>

    <!-- Visual Portfolio (Slider estilo Apple) -->
    <section id="portfolio" class="py-24 overflow-hidden">
      <div class="max-w-screen-xl mx-auto px-4 mb-12">
        <h2 class="text-3xl md:text-5xl font-bold">Nuestro Trabajo</h2>
        <p class="text-gray-400 mt-4 font-light">Explora la calidad de nuestras producciones.</p>
      </div>

      <div class="relative group">
        <!-- Slider Container -->
        <div id="slider" class="flex overflow-x-auto snap-x snap-mandatory scrollbar-hide gap-6 px-[10%] pb-10 cursor-grab active:cursor-grabbing">
          
          <!-- Slide 1 -->
          <div class="flex-none w-[85vw] md:w-[70vw] snap-center">
            <div class="relative aspect-video rounded-[2rem] overflow-hidden bg-gray-900 shadow-2xl">
              <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&q=90&w=1600" class="object-cover w-full h-full" alt="Interior" />
              <div class="absolute bottom-0 left-0 p-8 bg-gradient-to-t from-black/60 to-transparent w-full">
                <p class="text-xl font-medium">Interiores que enamoran</p>
              </div>
            </div>
          </div>

          <!-- Slide 2 -->
          <div class="flex-none w-[85vw] md:w-[70vw] snap-center">
            <div class="relative aspect-video rounded-[2rem] overflow-hidden bg-gray-900 shadow-2xl">
              <img src="https://images.unsplash.com/photo-1512917774080-9991f1c4c750?auto=format&fit=crop&q=90&w=1600" class="object-cover w-full h-full" alt="Vista Aérea" />
              <div class="absolute bottom-0 left-0 p-8 bg-gradient-to-t from-black/60 to-transparent w-full">
                <p class="text-xl font-medium">Vistas aéreas espectaculares</p>
              </div>
            </div>
          </div>

          <!-- Slide 3 -->
          <div class="flex-none w-[85vw] md:w-[70vw] snap-center">
            <div class="relative aspect-video rounded-[2rem] overflow-hidden bg-gray-900 shadow-2xl">
              <img src="https://images.pexels.com/photos/2724748/pexels-photo-2724748.jpeg?auto=compress&cs=tinysrgb&w=1600" class="object-cover w-full h-full" alt="Cocina" />
              <div class="absolute bottom-0 left-0 p-8 bg-gradient-to-t from-black/60 to-transparent w-full">
                <p class="text-xl font-medium">Diseño y detalle</p>
              </div>
            </div>
          </div>

          <!-- Slide 4 -->
          <div class="flex-none w-[85vw] md:w-[70vw] snap-center">
            <div class="relative aspect-video rounded-[2rem] overflow-hidden bg-gray-900 shadow-2xl">
              <img src="https://images.unsplash.com/photo-1600210492486-724fe5c67fb0?auto=format&fit=crop&q=90&w=1600" class="object-cover w-full h-full" alt="Residencia" />
              <div class="absolute bottom-0 left-0 p-8 bg-gradient-to-t from-black/60 to-transparent w-full">
                <p class="text-xl font-medium">Exclusividad en cada toma</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Apple-style Pagination Dots -->
        <div class="flex justify-center items-center mt-12 gap-4">
          <div class="bg-white/10 backdrop-blur-md px-4 py-2.5 rounded-full flex items-center gap-3">
            <div class="dot w-2 h-2 rounded-full bg-white/40 transition-all duration-300" data-index="0"></div>
            <div class="dot w-2 h-2 rounded-full bg-white/40 transition-all duration-300" data-index="1"></div>
            <div class="dot w-2 h-2 rounded-full bg-white/40 transition-all duration-300" data-index="2"></div>
            <div class="dot w-2 h-2 rounded-full bg-white/40 transition-all duration-300" data-index="3"></div>
          </div>
          <button class="bg-white/10 backdrop-blur-md p-2.5 rounded-full hover:bg-white/20 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
              <path d="m11.596 8.697-6.363 3.692c-.54.313-1.233-.066-1.233-.697V4.308c0-.63.692-1.01 1.233-.696l6.363 3.692a.802.802 0 0 1 0 1.393z"/>
            </svg>
          </button>
        </div>
      </div>
    </section>

    <script>
      const slider = document.getElementById('slider');
      const dots = document.querySelectorAll('.dot');

      if (slider && dots.length > 0) {
        const updateDots = () => {
          const scrollLeft = slider.scrollLeft;
          const width = slider.offsetWidth;
          // Calculamos el índice basado en el scroll (considerando el padding del contenedor)
          const index = Math.round(scrollLeft / (width * 0.75)); // 0.75 por el ancho de los slides (70-85vw)
          
          dots.forEach((dot, i) => {
            if (i === index) {
              dot.classList.add('w-6', 'bg-white');
              dot.classList.remove('w-2', 'bg-white/40');
            } else {
              dot.classList.add('w-2', 'bg-white/40');
              dot.classList.remove('w-6', 'bg-white');
            }
          });
        };

        slider.addEventListener('scroll', updateDots);
        // Inicializar
        updateDots();
      }
    </script>

    <style>
      .scrollbar-hide::-webkit-scrollbar {
        display: none;
      }
      .scrollbar-hide {
        -ms-overflow-style: none;
        scrollbar-width: none;
      }
    </style>

    <!-- Contact CTA -->
    <section id="contacto" class="py-32 text-center">
      <h2 class="text-4xl md:text-5xl font-bold mb-8">¿Listo para elevar tu propiedad?</h2>
      <p class="text-gray-400 mb-12 max-w-xl mx-auto">
        Atención personalizada en menos de 1 hora.
      </p>
      <a href="#" class="inline-block bg-white text-black px-12 py-5 rounded-full text-xl font-bold hover:scale-105 transition-transform">
        Hablar por WhatsApp
      </a>
    </section>

	</main>

  <footer class="py-12 border-t border-white/5 text-center text-gray-600 text-sm">
    <p>&copy; 2026 ARFA Studios. Deltebre - Tarragona.</p>
  </footer>
</Layout>

<style>
  @keyframes fade-in {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes slow-zoom {
    from { transform: scale(1); }
    to { transform: scale(1.1); }
  }
  .animate-fade-in {
    animation: fade-in 1.2s ease-out forwards;
  }
  .animate-slow-zoom {
    animation: slow-zoom 20s ease-in-out infinite alternate;
  }
</style>
